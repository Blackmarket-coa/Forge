{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "0.1.0",
  "identifier": "com.forge.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/forge-dev/forge/releases/latest/download/latest.json"
      ]
    }
  }
}
