{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "0.1.0",
  "identifier": "com.forge.app",
  "build": {
    "beforeDevCommand": "cd web && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd web && npm run build",
    "frontendDist": "../web/build"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Blackmarket-coa/Forge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzMDdFQjVERjUxQ0MzN0UKUldSK3d4ejFYZXNIZzdKZHlCRDFZS1l2MmJlY21SL29qNmRLRGYxZm1DY1A1RTlDRlRQOElEdG4K"
    }
  }
}
