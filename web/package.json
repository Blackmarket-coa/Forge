{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "notistack": "^3.0.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "ci": "react-scripts test --runInBand --reporters=default --reporters=jest-junit",
    "test-debug": "react-scripts --inspect-brk test --runInBand --no-cache",
    "eject": "react-scripts eject",
    "eslint": "eslint --fix 'src/**/*.ts*'",
    "prettier": "prettier --write \"src/**/*.ts*\"",
    "check": "prettier --check \"src/**/*.ts*\" && tsc -p . && eslint 'src/**/*.ts*'",
    "dev": "react-scripts start",
    "tauri": "tauri"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "devDependencies": {
    "@testing-library/dom": "^8.11.1",
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.0.2",
    "@types/node": "^16.11.7",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "@typescript-eslint/eslint-plugin": "^5.3.1",
    "@typescript-eslint/parser": "^5.3.1",
    "eslint": "^7.11.0",
    "eslint-plugin-jest": "^25.2.4",
    "eslint-plugin-react": "^7.27.0",
    "jest-junit": "^13.0.0",
    "prettier": "2.4.1",
    "prettier-plugin-organize-imports": "^2.3.4",
    "react-scripts": "^5.0.1",
    "sass": "^1.52.2",
    "typescript": "^4.4.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.9.3",
  "description": "Turn websites into desktop apps and manage Tauri projects, without writing code"
}
