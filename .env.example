# ─────────────────────────────────────────────────────────────────────────────
# Forge — environment variable reference
#
# Copy this file to .env and fill in the values for your environment.
# None of these variables are committed to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── License validation (Keygen) ───────────────────────────────────────────────
# Your Keygen account ID.  Required in production so that license keys are
# validated against the correct account.  Omitting this (or leaving it as the
# placeholder below) causes all validation calls to hit the demo sandbox, which
# will always return invalid.
KEYGEN_ACCOUNT_ID=your-keygen-account-id-here

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# DSN from your Sentry project settings.  When unset Sentry is disabled and
# errors are only written to the local log.  Recommended for production builds.
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls the log level filter passed to env_logger.  Examples:
#   RUST_LOG=forge=info          — info and above for forge crate only
#   RUST_LOG=debug               — debug and above for all crates
#   RUST_LOG=forge=debug,warn    — debug for forge, warn for everything else
# Defaults to "warn" when unset.
RUST_LOG=forge=info
